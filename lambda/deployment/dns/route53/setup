#!/bin/bash

source "$SERVICE_PATH/utils/log"

log info "🔍 Validating Route53 DNS configuration..."

# Get hosted zone ID from context
# For private/internal scopes, prefer hosted_zone_id if available; fall back to public zone.
# Use $VISIBILITY set by build_context — it accounts for http_enabled=false.
visibility="${VISIBILITY:-public}"
log info "   📋 VISIBILITY env var: '${VISIBILITY}' → resolved visibility: '$visibility'"

# Skip DNS entirely for event-driven scopes (no HTTP networking needed)
if [ "$visibility" = "event-driven" ]; then
  log info "   ⏭️  Skipping Route53 DNS - visibility is 'event-driven' (no HTTP networking)"
  return 0
fi

if [ "$visibility" = "private" ] || [ "$visibility" = "internal" ]; then
  hosted_zone_id="${HOSTED_PRIVATE_ZONE_ID:-}"
  if [ -n "$hosted_zone_id" ] && [ "$hosted_zone_id" != "null" ]; then
    log debug "   ✅ Using private hosted zone (visibility=$visibility)"
  else
    # Fall back to public zone if no private zone is configured
    hosted_zone_id="${HOSTED_PUBLIC_ZONE_ID:-}"
    log warn "   ⚠️  No HOSTED_PRIVATE_ZONE_ID configured, falling back to public zone"
  fi
else
  hosted_zone_id="${HOSTED_PUBLIC_ZONE_ID:-}"
fi

if [ -z "$hosted_zone_id" ] || [ "$hosted_zone_id" = "null" ]; then
  echo ""
  echo "   ❌ No hosted zone ID configured" >&2
  echo "" >&2
  echo "  🔧 How to fix:" >&2
  echo "    1. Ensure there is a scope-configurations provider at the correct NRN hierarchy level" >&2
  echo "    2. Set 'dns.hosted_public_zone_id' (public scopes) or 'dns.hosted_private_zone_id' (private/internal scopes)" >&2
  echo "" >&2
  return 1
fi
log debug "   ✅ hosted_zone_id=$hosted_zone_id"

# Extract scope information
scope_id=$(echo "$CONTEXT" | jq -r '.scope.id')
scope_slug=$(echo "$CONTEXT" | jq -r '.scope.slug')
application_slug=$(echo "$CONTEXT" | jq -r '.application.slug')
namespace_slug=$(echo "$CONTEXT" | jq -r '.namespace.slug')
account_slug=$(echo "$CONTEXT" | jq -r '.account.slug')

echo ""
log info "   📡 Fetching domain from Route 53 hosted zone..."

aws_output=$(aws route53 get-hosted-zone --id "$hosted_zone_id" 2>&1)
aws_exit_code=$?

if [ $aws_exit_code -ne 0 ]; then
  echo ""
  echo "   ❌ Failed to fetch Route 53 hosted zone information" >&2
  echo "" >&2

  if echo "$aws_output" | grep -q "NoSuchHostedZone"; then
    echo "  🔎 Error: Hosted zone '$hosted_zone_id' does not exist" >&2
    echo "" >&2
    echo "  💡 Possible causes:" >&2
    echo "    • The hosted zone ID is incorrect or has a typo" >&2
    echo "    • The hosted zone was deleted" >&2
    echo "" >&2
    echo "  🔧 How to fix:" >&2
    echo "    1. Verify the hosted zone exists: aws route53 list-hosted-zones" >&2
    echo "    2. Update 'hosted_public_zone_id' in the AWS cloud-provider configuration" >&2

  elif echo "$aws_output" | grep -q "AccessDenied\|not authorized"; then
    echo "  🔒 Error: Permission denied when accessing Route 53" >&2
    echo "" >&2
    echo "  💡 Possible causes:" >&2
    echo "    • The AWS credentials don't have Route 53 read permissions" >&2
    echo "" >&2
    echo "  🔧 How to fix:" >&2
    echo "    1. Ensure the IAM policy includes route53:GetHostedZone permission" >&2

  else
    echo "  📋 Error details:" >&2
    echo "$aws_output" | sed 's/^/    /' >&2
  fi

  echo "" >&2
  return 1
fi

network_domain=$(echo "$aws_output" | jq -r '.HostedZone.Name' | sed 's/\.$//')

if [ -z "$network_domain" ] || [ "$network_domain" = "null" ]; then
  echo ""
  echo "   ❌ Failed to extract domain name from hosted zone response" >&2
  echo "" >&2
  return 1
fi

log debug "   ✅ domain=$network_domain"

# Generate subdomain based on pattern
use_account_slug="${USE_ACCOUNT_SLUG:-true}"

if [ "$use_account_slug" = "true" ]; then
  network_subdomain="${namespace_slug}-${application_slug}-${scope_slug}.${account_slug}"
else
  network_subdomain="${namespace_slug}-${application_slug}-${scope_slug}"
fi

log debug "   ✅ subdomain=$network_subdomain"

# Full domain
scope_domain="${network_subdomain}.${network_domain}"
log debug "   ✅ full_domain=$scope_domain"

DNS_FULL_DOMAIN="$scope_domain"
export DNS_FULL_DOMAIN

TOFU_VARIABLES=$(echo "$TOFU_VARIABLES" | jq \
  --arg hosted_zone_id "$hosted_zone_id" \
  --arg domain "$network_domain" \
  --arg subdomain "$network_subdomain" \
  --arg full_domain "$scope_domain" \
  '. + {
    dns_hosted_zone_id: $hosted_zone_id,
    dns_domain: $domain,
    dns_subdomain: $subdomain,
    dns_full_domain: $full_domain
  }')

echo ""
log info "   📝 Setting scope domain to '$scope_domain'..."

np_output=$(np scope patch --id "$scope_id" --body "{\"domain\":\"$scope_domain\"}" --format json 2>&1)
np_exit_code=$?

if [ $np_exit_code -ne 0 ]; then
  echo ""
  echo "   ❌ Failed to update scope domain" >&2
  echo "" >&2

  if echo "$np_output" | grep -q "unauthorized\|forbidden\|401\|403"; then
    echo "  🔒 Error: Permission denied" >&2
    echo "" >&2
    echo "  💡 Possible causes:" >&2
    echo "    • The nullplatform API Key doesn't have 'Developer' permissions" >&2
    echo "" >&2
  else
    echo "  📋 Error details:" >&2
    echo "$np_output" | sed 's/^/    /' >&2
  fi

  echo "" >&2
  return 1
fi

log debug "   ✅ Scope domain set successfully"

echo ""
log info "✨ Route53 DNS configured successfully"
echo ""

# Add module to composition list
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

module_name="${script_dir}/modules"
if [[ -n $MODULES_TO_USE ]]; then
  MODULES_TO_USE="$MODULES_TO_USE,$module_name"
else
  MODULES_TO_USE="$module_name"
fi
